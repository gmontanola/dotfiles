## ZSH options

# Menu like completion selection
zstyle ':completion:*' menu select

# Case-Insensitive matching
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'

## fzf
source /usr/share/fzf/key-bindings.zsh
source /usr/share/fzf/completion.zsh

## History
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_VERIFY
setopt HIST_REDUCE_BLANKS
setopt EXTENDED_HISTORY
setopt SHAREHISTORY
setopt INCAPPENDHISTORY

HISTORY_IGNORE="&:ls:[bf]g:exit:reset:clear:cd:cd ..:cd.:.."
HISTSIZE=25000
SAVEHIST=10000
HISTFILE=~/.zsh_history

## pyenv
export PYENV_ROOT="$HOME/.pyenv"

## PATH
export PATH=~/.cargo/bin:~/.local/bin:$PYENV_ROOT/bin:$PATH

## ENV
export EDITOR=nvim

## Aliases
alias k=kubectl

alias ls='exa -bh --color=auto'
alias l='ls'
alias ll='ls -lbt modified --color=auto'
alias l.='ls -d .* --color=auto'

alias mv='mv -i'
alias cp='cp -i'

alias grep='grep --color=auto'

alias gs='git status'
alias ..="cd .."

# GPG Agent
unset SSH_AGENT_PID
if [ "${gnupg_SSH_AUTH_SOCK_by:-0}" -ne $$ ]; then
  export SSH_AUTH_SOCK="$(gpgconf --list-dirs agent-ssh-socket)"
fi
export GPG_TTY=$(tty)
gpg-connect-agent updatestartuptty /bye >/dev/null

## Zinit

# Autosuggest & Completion
zinit wait lucid light-mode for \
  atinit"zicompinit; zicdreplay" \
      zdharma/fast-syntax-highlighting \
  atload"_zsh_autosuggest_start" \
      zsh-users/zsh-autosuggestions \
  blockf atpull'zinit creinstall -q $PWD' \
      zsh-users/zsh-completions

# LS_COLORS
zinit pack for ls_colors

# Z
zinit load agkozak/zsh-z

## pyenv init
if command -v pyenv 1>/dev/null 2>&1; then
  eval "$(pyenv init -)"
fi

## Starship.rs
export STARSHIP_CONFIG=~/.config/starship/starship.toml
eval "$(starship init zsh)"
